# ── Simple Syllabus Scraper ──────────────────────────────────────────────────
# Comma-separated subject codes to scrape (ignored when --all-departments is passed)
DEPARTMENTS=CSCE,ISEN,STAT,ECEN

# Comma-separated term names matching SimpleSyllabus display names
TARGET_TERMS=Spring 2026,Summer 2026,Fall 2026

# Seconds to wait between requests
DELAY=1.0

# Maximum HTTP retry attempts before giving up on a request
MAX_RETRIES=5

# Maximum total download size in megabytes (0 = unlimited)
MAX_MB=0

# Set to "true" to only include graduate courses (course number >= 600)
GRADUATE_ONLY=true

# Root directory for all downloaded output
OUTPUT_DIR=./output

# ── Howdy Portal Scraper ─────────────────────────────────────────────────────
# Comma-separated TAMU term codes (202611=Spring 2026, 202621=Summer 2026, 202631=Fall 2026)
# TARGET_TERMS=202611,202621,202631

# Seconds to wait between syllabus PDF downloads
# DOWNLOAD_DELAY=2.0
